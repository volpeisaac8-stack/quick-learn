<!DOCTYPE html>
<html>
<head>
    <title><%= topicData.title %></title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<script>
if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js');
}
</script>
<body>

<h1><%= topicData.title %></h1>

<p><%= topicData.extract %></p>

<h3>Modes</h3>
<a href="/topic?topic=<%= topicData.title %>&mode=summary">Summary</a> |
<a href="/topic?topic=<%= topicData.title %>&mode=deep">Deep Dive</a> |
<a href="/topic?topic=<%= topicData.title %>&mode=flashcards">Flashcards</a>

<hr>

<% if (mode === "deep" && deepContent) { %>
    <h2>Deep Dive</h2>
    <div>
        <%- deepContent %>
    </div>
<% } %>

<% if (mode === "flashcards") { %>
    <h2>Flashcards</h2>
    <% flashcards.forEach(card => { %>
        <div class="card">
            <p><strong><%= card.question %></strong></p>
            <details>
                <summary>Show Answer</summary>
                <p><%= card.answer %></p>
            </details>
        </div>
    <% }) %>
<% } %>

<form action="/star" method="POST">
    <input type="hidden" name="topic" value="<%= topicData.title %>">
    <button>⭐ Star This Topic</button>
</form>

<br>
<a href="/saved">View Saved Topics</a> |
<a href="/">Back Home</a>

</body>
</html>

<style>
    body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 20px;

    display: flex;
    flex-direction: column;
    align-items: center;   /* centers horizontally */
    text-align: center;    /* centers text */
}

h1, h2, h3 {
    text-align: center;
}

form {
    margin: 20px 0;
}

input {
    padding: 10px;
    width: 250px;
    max-width: 90%;
}

button {
    padding: 10px 15px;
    margin-top: 10px;
    cursor: pointer;
}

.card {
    border: 1px solid #ccc;
    padding: 15px;
    margin: 15px 0;
    border-radius: 8px;
    width: 100%;
    max-width: 500px;
}
</style>