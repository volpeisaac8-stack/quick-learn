<!DOCTYPE html>
<html>
<head>
<title><%= topicData.title %></title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="/styles.css">
</head>

<body>

<div class="container">

<h1><%= topicData.title %></h1>

<!-- STUDY CONTENT CARD (ALWAYS SHOW) -->
<div class="card">

<% if(mode === "deep" && deepContent){ %>

<h2>Deep Dive</h2>

<div>
<%- deepContent %>
</div>

<% } else { %>

<p><%= topicData.extract %></p>

<% } %>

</div>

<!-- VIDEO SECTION -->
<% if(videos && videos.length > 0){ %>

<h2>Related Videos</h2>

<% videos.forEach(video => { %>

<div class="card">

<p><%= video.snippet.title %></p>

<iframe width="100%" height="220"
src="https://www.youtube.com/embed/<%= video.id.videoId %>"
allowfullscreen>
</iframe>

</div>

<% }) %>

<% } %>

<!-- ACTION BUTTONS -->

<a href="/topic?topic=<%= topicData.title %>&mode=deep">
<button>🔍 Deep Dive Mode</button>
</a>

<a href="/topic?topic=<%= topicData.title %>">
<button>📚 Summary Mode</button>
</a>

<a href="/topic?topic=<%= topicData.title %>&videos=true">
<button>🎥 Related Videos</button>
</a>

<form action="/star" method="POST">
<input type="hidden" name="topic" value="<%= topicData.title %>">
<button>⭐ Save Topic</button>
</form>

<br>

<a href="/">
<button>Home</button>
</a>

</div>

</body>
</html>