<!DOCTYPE html>
<html>
<head>
<link rel="manifest" href="/manifest.json">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<meta name="apple-mobile-web-app-title" content="Quick Learn">
<title>Quick Learn</title>
</head>

<body style="font-family:Arial; max-width:600px; margin:auto; padding:40px; background:#f5f7fb;">

<h1>📚 Quick Learn Engine</h1>

<form action="/study" method="POST">

<input
    type="text"
    name="topic"
    placeholder="Enter topic..."
    required
    style="width:100%; padding:12px; font-size:16px; margin-bottom:15px;"
/>

<div style="margin-bottom:15px;">

<label>
<input type="radio" name="mode" value="summary" checked>
Summary Mode
</label>

<label style="margin-left:20px;">
<input type="radio" name="mode" value="history">
History Mode
</label>

</div>

<button type="submit"
style="padding:12px 20px; font-size:16px; background:#4f46e5; color:white; border:none; border-radius:8px;">
Start Learning
</button>

</form>

</body>
</html>